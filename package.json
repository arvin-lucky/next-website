{
	"name": "next-website",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "API_ENV=qa next dev",
		"build": "next build",
		"build:qa": "API_ENV=qa next build",
		"start": "next start",
		"start:qa": "npm run build:qa && next start",
		"lint": "eslint",
		"prepare": "husky",
		"format:eslint": "eslint --fix",
		"format:prettier": "prettier --write .",
		"version:next": "node ./scripts/increment-version.js last && npm run prettier",
		"deploy": "touch out/.nojekyll && gh-pages -d out -t"
	},
	"dependencies": {
		"@headlessui/react": "2.2.9",
		"@heroicons/react": "2.2.0",
		"classnames": "2.5.1",
		"next": "16.1.6",
		"next-seo": "7.2.0",
		"next-themes": "0.4.6",
		"react": "19.2.3",
		"react-dom": "19.2.3"
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.2",
		"@commitlint/config-conventional": "20.4.2",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"gh-pages": "6.3.0",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"prettier": "3.8.1",
		"tailwindcss": "^4",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,css}": [
			"prettier --write",
			"eslint --fix"
		]
	}
}
